# Web demo env — copy to .env.demo for portfolio embed builds.
EXPO_PUBLIC_DEMO_MODE=true
EXPO_PUBLIC_WEB_BASE_PATH=/lingoleaf/demo

# Demo API on portfolio site (defaults to same-origin /api/demo when embedded)
# EXPO_PUBLIC_DEMO_API_BASE=https://connorjpepin.com/api/demo

# Parent portfolio URL for standalone demo navigation (optional).
# EXPO_PUBLIC_PORTFOLIO_URL=https://connorjpepin.com/

# Supabase is optional in demo mode — local IndexedDB holds reader progress and vocabulary.
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_KEY=

# Web builds skip AdMob/RevenueCat/notifications; leave blank unless testing auth providers.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
