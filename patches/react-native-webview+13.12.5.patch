+    static dispatch_once_t onceToken;
+    dispatch_once(&onceToken, ^{
+        // Swizzle WKContentView canPerformAction:withSender: to suppress native edit menu
+        Class wkContentViewClass = NSClassFromString(@"WKContentView");
+        if (!wkContentViewClass) return;
+        SEL canPerformSel = @selector(canPerformAction:withSender:);
+        Method originalMethod = class_getInstanceMethod(wkContentViewClass, canPerformSel);
+        if (!originalMethod) return;
+        IMP originalIMP = method_getImplementation(originalMethod);
+        IMP newIMP = imp_implementationWithBlock(^BOOL(id _self, SEL action, id sender) {
+            UIView *view = (UIView *)_self;
+            while (view != nil) {
+                if ([view isKindOfClass:[RNCWKWebView class]]) {
+                    RNCWKWebView *wv = (RNCWKWebView *)view;
+                    if (!wv.menuItems || wv.menuItems.count == 0) {
+                        return NO;
+                    }
+                    break;
+                }
+                view = view.superview;
+            }
+            return ((BOOL(*)(id, SEL, SEL, id))originalIMP)(_self, canPerformSel, action, sender);
+        });
+        method_setImplementation(originalMethod, newIMP);
+    });
+}
