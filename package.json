{
  "name": "lingoleaf",
  "version": "1.0.1",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "security:check": "bash scripts/security-check.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "sync:gutendex": "node scripts/sync-gutendex.mjs",
    "ios:build:prod": "./scripts/ios-eas-local-build.sh",
    "ios:submit:prod": "./scripts/ios-eas-submit.sh",
    "ios:release:prod": "./scripts/ios-eas-local-build.sh && ./scripts/ios-eas-submit.sh",
    "postinstall": "patch-package && node scripts/patch-webview-edit-menu.js && node scripts/patch-epubjs-bounces.js"
  },
  "dependencies": {
    "@epubjs-react-native/core": "^1.0.0",
    "@epubjs-react-native/expo-file-system": "^1.1.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/slider": "4.5.5",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^17.2.3",
    "epubjs": "^0.3.93",
    "expo": "~52.0.0",
    "expo-apple-authentication": "~7.1.3",
    "expo-auth-session": "~6.0.3",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.0",
    "expo-notifications": "~0.29.14",
    "expo-sharing": "~13.0.1",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~0.27.5",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-google-mobile-ads": "^16.0.1",
    "react-native-purchases": "^9.10.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-webview": "^13.12.5",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.12",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "jest": "^30.2.0",
    "jest-expo": "~52.0.0",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "react-test-renderer": "^18.3.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@epubjs-react-native/core",
          "@epubjs-react-native/expo-file-system",
          "dotenv",
          "epubjs"
        ],
        "listUnknownPackages": false
      }
    },
    "install": {
      "exclude": [
        "expo",
        "jest"
      ]
    }
  },
  "private": true
}
