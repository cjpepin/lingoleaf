# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Demo backend (optional — safe to publish; anon key only)
# Copy these into README "Try the demo" after rotating keys per SECURITY.md
# EXPO_PUBLIC_SUPABASE_URL=https://your-demo-project.supabase.co
# EXPO_PUBLIC_SUPABASE_KEY=your-demo-anon-key
# ---------------------------------------------------------------------------

# Google OAuth (Sign in with Google) — create in Google Cloud Console → APIs & Services → Credentials:
# - Create OAuth 2.0 Client ID: "iOS" (bundle ID com.lingoleaf.app) → EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID
# - Create OAuth 2.0 Client ID: "Android" (package com.lingoleaf.app + SHA-1) → EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID
# - Create OAuth 2.0 Client ID: "Web application" → use same Client ID in Supabase Auth → Providers → Google; set secret there.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Google Translate API (Edge Function secret — do NOT expose to client)
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# Service Role Key (local scripts / Edge Functions only — NEVER commit or ship in the app)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AdMob (defaults in app.config.ts use Google test IDs)
EXPO_PUBLIC_ADMOB_IOS_APP_ID=
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_IOS=
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID_ANDROID=

# RevenueCat / Premium (iOS public SDK key is client-safe; secret keys stay on server)
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=your-revenuecat-ios-api-key
EXPO_PUBLIC_PREMIUM_SKU_MONTHLY=lingoleaf_premium_monthly
EXPO_PUBLIC_PREMIUM_SKU_YEARLY=lingoleaf_premium_yearly
EXPO_PUBLIC_PREMIUM_SKU_LIFETIME=lingoleaf_premium_lifetime

# Edge Function secrets (set via: supabase secrets set NAME=value)
# REVENUECAT_SECRET_API_KEY=
# REVENUECAT_WEBHOOK_AUTH_HEADER='Bearer your-shared-webhook-secret'
# OPENAI_API_KEY=          # optional — study-pack-metadata falls back without it
# OPENAI_MODEL=

# Auth confirmation/reset emails: configure Supabase Dashboard → Authentication → SMTP
# Recommended provider: Resend (smtp.resend.com, username: resend, password: API key)
