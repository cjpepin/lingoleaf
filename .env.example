# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your-anon-key

# Google OAuth (Sign in with Google) — create in Google Cloud Console → APIs & Services → Credentials:
# - Create OAuth 2.0 Client ID: "iOS" (bundle ID com.lingoleaf.app) → EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID
# - Create OAuth 2.0 Client ID: "Android" (package com.lingoleaf.app + SHA-1) → EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID
# - Create OAuth 2.0 Client ID: "Web application" → use same Client ID in Supabase Auth → Providers → Google; set secret there.
# If you get "deleted_client" (401), the IDs in .env point to a deleted client — create new clients and update these + Supabase.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Google Translate API
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# Service Role Key (for Edge Functions only - DO NOT expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key